# CS.Money session cookie (csgo_ses value from cs.money)
CSMONEY_SESSION=your_csgo_ses_cookie_here

# Steam cookies from steamcommunity.com
STEAM_LOGIN_SECURE=your_steamLoginSecure_cookie_here
STEAM_SESSION_ID=your_sessionid_cookie_here

# Polling interval in seconds (default: 10)
POLL_INTERVAL=10

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
